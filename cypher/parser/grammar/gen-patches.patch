+// peekHasWithBeforeReturn looks ahead in the token stream to determine
+// whether another top-level WITH clause appears before the next RETURN or
+// end-of-input. It is used by [MultiPartQ] to decide whether to loop for
+// another (updatingStatement* withSt) iteration after the current WITH.
+//
+// Top-level means: not nested inside parentheses or brackets — so EXISTS{},
+// COUNT{}, and CALL { … } subqueries that happen to contain a WITH do not
+// trigger a false positive.
+func (p *CypherParser) peekHasWithBeforeReturn() bool {
+	const maxLook = 4096
+	depth := 0
+	for i := 1; i <= maxLook; i++ {
+		tok := p.GetTokenStream().LT(i).GetTokenType()
+		switch tok {
+		case antlr.TokenEOF, CypherParserRETURN:
+			return false
+		case CypherParserWITH:
+			if depth == 0 {
+				return true
+			}
+		case CypherParserLPAREN, CypherParserLBRACK, CypherParserLBRACE:
+			depth++
+		case CypherParserRPAREN, CypherParserRBRACK, CypherParserRBRACE:
+			if depth > 0 {
+				depth--
+			}
+		}
+	}
+	return false
+}
